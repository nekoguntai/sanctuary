{
  "name": "sanctuary-gateway",
  "version": "0.8.29",
  "description": "Public API gateway for Sanctuary mobile apps",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=junit"
  },
  "dependencies": {
    "@parse/node-apn": "^8.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.16",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.16"
  }
}
