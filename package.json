{
  "name": "sanctuary",
  "private": true,
  "version": "0.8.28",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:full": "npm run test:coverage && npm run test:backend:coverage && cd gateway && npm run test:coverage",
    "test:integration": "./scripts/run-integration-tests.sh",
    "test:all": "npm run test:run && npm run test:backend",
    "test:backend": "cd server && npm test",
    "test:backend:watch": "cd server && npm run test:watch",
    "test:backend:coverage": "cd server && npm run test:coverage",
    "test:docker": "docker compose -f docker-compose.test.yml run --rm test-all",
    "test:docker:backend": "docker compose -f docker-compose.test.yml run --rm backend-test",
    "test:docker:frontend": "docker compose -f docker-compose.test.yml run --rm frontend-test",
    "test:docker:coverage": "docker compose -f docker-compose.test.yml run --rm backend-coverage && docker compose -f docker-compose.test.yml run --rm frontend-coverage",
    "test:docker:clean": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
    "test:e2e": "playwright test",
    "test:e2e:render": "playwright test --project=chromium e2e/render-regression.spec.ts",
    "test:e2e:render:update": "playwright test --project=chromium e2e/render-regression.spec.ts --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:hygiene": "node scripts/test-hygiene.mjs",
    "typecheck": "npm run typecheck:app",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json --noUnusedLocals --noUnusedParameters",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json --noUnusedLocals --noUnusedParameters",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json --noUnusedLocals --noUnusedParameters",
    "test:mutation": "stryker run",
    "test:mutation:backend": "cd server && npx stryker run",
    "test:mutation:critical:backend": "cd server && npm run test:mutation:critical:gate"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@keystonehq/bc-ur-registry": "^0.7.1",
    "@ledgerhq/hw-app-btc": "^10.13.0",
    "@ledgerhq/hw-transport-webusb": "^6.29.13",
    "@ledgerhq/ledger-bitcoin": "^0.3.1",
    "@ngraveio/bc-ur": "^1.1.13",
    "@tanstack/react-query": "^5.90.12",
    "@trezor/connect-web": "^9.7.0",
    "@yudiel/react-qr-scanner": "^2.5.0",
    "bitbox02-api": "^0.15.1",
    "bitcoinjs-lib": "^7.0.1",
    "cbor-x": "^1.6.0",
    "lucide-react": "^1.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.14.0",
    "react-virtuoso": "^4.17.0",
    "recharts": "^3.5.1",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.49.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-hid": "^1.0.6",
    "@types/w3c-web-serial": "^1.0.8",
    "@types/w3c-web-usb": "^1.0.13",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.16",
    "jsdom": "^29.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.5",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.0.16"
  }
}
