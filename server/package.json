{
  "name": "sanctuary-server",
  "version": "0.8.25",
  "description": "Backend API server for Sanctuary Bitcoin Wallet",
  "main": "dist/server/src/index.js",
  "prisma": {
    "seed": "node --experimental-specifier-resolution=node dist/prisma/seed.js"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc",
    "start": "node dist/server/src/index.js",
    "pretest": "prisma generate",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --no-file-parallelism --maxWorkers 1",
    "test:integration:db": "DATABASE_URL='postgresql://sanctuary:sanctuary@localhost:5432/sanctuary_test?schema=public' npm run test:integration",
    "test:ci": "vitest run --coverage --reporter=junit",
    "test:bitcoin": "vitest run tests/unit/services/bitcoin",
    "test:pool": "vitest run tests/unit/services/bitcoin/electrumPool.test.ts tests/unit/services/bitcoin/nodeClient.test.ts",
    "test:api": "vitest run tests/unit/api",
    "test:contract": "vitest run tests/contract",
    "test:security": "vitest run --testNamePattern='Authentication|Encryption|Two-Factor|Password'",
    "test:fast": "vitest run --changed",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:mutation": "stryker run",
    "test:mutation:critical": "stryker run stryker.critical.config.mjs",
    "test:mutation:critical:gate": "npm run test:mutation:critical && node scripts/mutation/check-critical-mutation-gate.mjs",
    "check:prisma-imports": "tsx scripts/check-prisma-imports.ts",
    "prepare": "cd .. && husky server/.husky",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "bitcoin",
    "wallet",
    "api",
    "sanctuary"
  ],
  "author": "nekoguntai",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "bullmq": "^5.73.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "i18next": "^26.0.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "socks": "^2.8.7",
    "socks-proxy-agent": "^8.0.5",
    "tiny-secp256k1": "^2.2.3",
    "ws": "^8.18.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.16",
    "ecpair": "^3.0.1",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "prisma": "^7.6.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.16"
  }
}
